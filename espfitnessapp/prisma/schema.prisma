generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// User model - extends NextAuth User
model User {
  id                  String    @id @default(cuid())
  email               String    @unique
  emailVerified       DateTime?
  name                String?
  image               String?
  password            String?
  bodyweight          Float?
  onboardingCompleted Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Relations
  accounts           Account[]
  sessions           Session[]
  workoutPlans       WorkoutPlan[]
  workoutLogs        WorkoutLog[]
  chatSessions       ChatSession[]
  chatMessages       ChatMessage[]
  stats              UserStats?
  pendingAdjustments PendingAdjustment[]
}

// NextAuth Account model
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

// NextAuth Session model
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// NextAuth VerificationToken model
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// User Statistics
model UserStats {
  id                 String   @id @default(cuid())
  userId             String   @unique
  currentStreak      Int      @default(0)
  longestStreak      Int      @default(0)
  personalRecords    Json     @default("{}")
  progressPercentage Float    @default(0)
  lastWorkout        DateTime?
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Workout Plan
model WorkoutPlan {
  id            String    @id @default(cuid())
  userId        String
  goal          String
  aiContext     Json?
  status        String    @default("draft") // draft, active, completed, archived
  weeksDuration Int       @default(1)
  startDate     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  workoutDays        WorkoutDay[]
  workoutLogs        WorkoutLog[]
  chatMessages       ChatMessage[]
  pendingAdjustments PendingAdjustment[]

  @@index([userId])
  @@index([status])
}

// Workout Day
model WorkoutDay {
  id            String    @id @default(cuid())
  planId        String
  dayNumber     Int
  dayName       String
  scheduledDate DateTime?
  workoutType   String    // legs, push, pull, full-body, arms, rest
  workoutColor  String    @default("#404040")
  isGenerated   Boolean   @default(false)
  metadata      Json?

  // Relations
  plan        WorkoutPlan  @relation(fields: [planId], references: [id], onDelete: Cascade)
  exercises   Exercise[]
  workoutLogs WorkoutLog[]

  @@index([planId])
  @@index([dayNumber])
  @@index([scheduledDate])
  @@index([workoutType])
  @@index([planId, workoutType, scheduledDate])
}

// Exercise
model Exercise {
  id              String  @id @default(cuid())
  dayId           String
  name            String
  sets            Int
  reps            Int
  weightType      String  @default("ABSOLUTE") // BW, 1RM, ABSOLUTE
  weightValue     Float
  restTime        Int     @default(90) // Rest time in seconds
  exerciseType    String  @default("strength") // strength, cardio_time, mobility_time, distance, interval, amrap, emom, tabata, tempo
  progression     Json?
  movementDetails Json?
  order           Int     @default(0)
  
  // Complex exercise type fields
  distance        Float?              // Target distance (e.g., 40 for 40 feet)
  distanceUnit    String? @default("feet") // feet, yards
  intervals       Json?               // Interval structure with phases
  tempo           String?             // Tempo pattern (e.g., "3-1-3-1")
  timeCap         Int?                // Time cap in seconds for AMRAP/timed exercises

  // Relations
  day          WorkoutDay    @relation(fields: [dayId], references: [id], onDelete: Cascade)
  exerciseLogs ExerciseLog[]

  @@index([dayId])
  @@index([order])
}

// Workout Log
model WorkoutLog {
  id          String    @id @default(cuid())
  userId      String
  planId      String
  dayId       String
  workoutDate DateTime  @default(now())
  status      String    @default("in_progress") // in_progress, completed, skipped
  startedAt   DateTime?
  completedAt DateTime?
  feedback    Json?
  createdAt   DateTime  @default(now())

  // Relations
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan         WorkoutPlan   @relation(fields: [planId], references: [id], onDelete: Cascade)
  day          WorkoutDay    @relation(fields: [dayId], references: [id], onDelete: Cascade)
  exerciseLogs ExerciseLog[]

  @@index([userId])
  @@index([planId])
  @@index([dayId])
  @@index([workoutDate])
}

// Exercise Log
model ExerciseLog {
  id            String  @id @default(cuid())
  logId         String
  exerciseId    String
  setsCompleted Int
  repsPerSet    Json    // Array of reps per set [8, 8, 7]
  weightUsed    Float
  isPR          Boolean @default(false)
  notes         String?

  // Relations
  log      WorkoutLog @relation(fields: [logId], references: [id], onDelete: Cascade)
  exercise Exercise   @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@index([logId])
  @@index([exerciseId])
}

// Chat Session
model ChatSession {
  id        String   @id @default(cuid())
  userId    String
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@index([userId])
  @@index([createdAt])
}

// Chat Message
model ChatMessage {
  id        String   @id @default(cuid())
  sessionId String
  userId    String
  planId    String?
  role      String   // user, assistant, system
  content   String   @db.Text
  metadata  Json?
  createdAt DateTime @default(now())

  // Relations
  session ChatSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan    WorkoutPlan? @relation(fields: [planId], references: [id], onDelete: SetNull)

  @@index([sessionId])
  @@index([userId])
  @@index([planId])
  @@index([createdAt])
}

// Pending Adjustment - Stores AI suggestions awaiting user approval
model PendingAdjustment {
  id           String   @id @default(cuid())
  userId       String
  planId       String
  workoutLogId String   @unique
  suggestions  Json     // Array of exercise adjustments
  status       String   @default("pending") // pending, approved, rejected
  createdAt    DateTime @default(now())
  expiresAt    DateTime

  // Relations
  user User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan WorkoutPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([workoutLogId])
  @@index([status])
}
